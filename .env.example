# ==========================
# OCR Reasoning Engine — Environment Configuration
# ==========================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ---- Model ----
FAI_LLM_MODEL=./models/qwen2.5-7b-awq
FAI_LLM_MODEL_VERSION=v2.0.0
FAI_LLM_VLLM_BASE_URL=http://127.0.0.1:8100/v1

# ---- Inference Parameters ----
FAI_LLM_MAX_TOKENS=512
FAI_LLM_TEMPERATURE=0.0
FAI_LLM_GPU_MEMORY_UTILIZATION=0.85
FAI_LLM_MAX_MODEL_LEN=2048
FAI_LLM_MAX_NUM_SEQS=2

# ---- Authentication ----
# Generate with: openssl rand -hex 32
JWT_SECRET=
INTERNAL_SERVICE_TOKEN=

# ---- Logging ----
LOG_LEVEL=INFO
